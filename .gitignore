# Flutter/Dart build output
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies

# macOS app bundles and disk images
*.dmg
*.app

# Node / Electron artifacts (not part of Flutter build)
node_modules/
.webpack/
out/
dist/

# Environment variables
.env
.env.test

# macOS system files
.DS_Store

# whisper.xcframework — keep only the macOS slice; dSYMs are not needed in the repo
macos/whisper.xcframework/ios-*/
macos/whisper.xcframework/tvos-*/
macos/whisper.xcframework/xros-*/
macos/whisper.xcframework/*/dSYMs/
